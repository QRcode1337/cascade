# Database connections (Supabase)
DATABASE_URL="postgres://postgres.PROJECT_REF:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_DATABASE_URL="postgres://postgres.PROJECT_REF:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# Supabase Auth (PUBLIC - safe for client-side)
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# Supabase Service Role (PRIVATE - server-side only)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Email (Resend)
RESEND_API_KEY="re_your_key_here"

# Encryption
ENCRYPTION_KEY=""

# OpenAI
OPENAI_API_KEY="sk-..."

# Slack
SLACK_BOT_TOKEN="xoxb-..."
SLACK_ALERT_CHANNEL="#cascade-alerts"

# Worker
WORKER_CONCURRENCY=5
PGBOSS_DATABASE_URL="${DIRECT_DATABASE_URL}"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NODE_ENV="development"
