{
  "name": "@cascade/runtime",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cascade/schemas": "workspace:*",
    "expr-eval": "^2.0.2",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@cascade/typescript-config": "workspace:*",
    "@types/mustache": "^4.2.5",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
